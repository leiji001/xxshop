{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 280,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",

  "plugins": ["@trivago/prettier-plugin-sort-imports"],

  "importOrder": ["^vue$", "<THIRD_PARTY_MODULES>", "^@/(.*)$", "^[./]"],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
